#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${1:-$PWD}"

usage() {
  cat <<'EOF'
usage: bin/install-codex-rules [target-repo]

Copies missing Codex app rule templates into target-repo.
Existing files are left untouched.
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ ! -d "$TARGET" ]; then
  printf 'target is not a directory: %s\n' "$TARGET" >&2
  exit 1
fi

TARGET_ABS="$(cd "$TARGET" && pwd)"

if [ "$TARGET_ABS" = "$ROOT" ]; then
  printf 'refusing to install templates into this rules repo; pass a target repo path\n' >&2
  exit 1
fi

mkdir -p "$TARGET/docs/adr" "$TARGET/.codex"

copy_if_missing() {
  local src=$1
  local dst=$2

  if [ -e "$dst" ]; then
    printf 'skip existing %s\n' "${dst#$TARGET/}"
    return
  fi

  cp "$src" "$dst"
  printf 'create %s\n' "${dst#$TARGET/}"
}

FILES=(
  AGENTS.md
  docs/agent-workflow.md
  docs/execution-packet.md
  docs/startup-agent-workflow.md
  docs/project-routing.md
  docs/tools.md
  docs/workflow-packaging-audit.md
  docs/adr/0000-template.md
  docs/queue.md
  docs/knowledge.md
  .codex/config.toml
)

for path in "${FILES[@]}"; do
  copy_if_missing "$ROOT/templates/$path" "$TARGET/$path"
done
